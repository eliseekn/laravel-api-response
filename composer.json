{
  "name": "eliseekn/laravel-api-response",
  "description": "Send JSON response from your API.",
  "keywords": [
    "eliseekn",
    "laravel-api-response"
  ],
  "homepage": "https://github.com/eliseekn/laravel-api-response",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "N'Guessan Kouadio Elisée",
      "email": "eliseekn@gmail.com",
      "homepage": "https://eliseekn.netlify.app",
      "role": "Developer"
    }
  ],
  "minimum-stability": "stable",
  "require": {
    "php": "^8.3",
    "illuminate/http": "^13.11"
  },
  "autoload": {
    "psr-4": {
      "Eliseekn\\LaravelApiResponse\\": "src"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "aliases": {
        "LaravelApiResponse": "Eliseekn\\LaravelApiResponse\\LaravelApiResponseFacade"
      }
    }
  }
}
